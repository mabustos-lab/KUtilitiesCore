<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<OutputType>Library</OutputType>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>disable</Nullable>
		<LangVersion>latest</LangVersion>
		<Title>KUtilitiesCore.Dal</Title>
		<Description>Capa de acceso a datos con soporte para Unit of Work e inserciones masivas.</Description>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
	</PropertyGroup>
	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>
	<ItemGroup>
	  <Compile Remove="Paging\**" />
	  <Compile Remove="SPHelper\**" />
	  <EmbeddedResource Remove="Paging\**" />
	  <EmbeddedResource Remove="SPHelper\**" />
	  <None Remove="Paging\**" />
	  <None Remove="SPHelper\**" />
	</ItemGroup>
	<ItemGroup>
	  <Compile Remove="Exceptions\RepositoryException.cs" />
	  <Compile Remove="UOW\IDaoRepositoryProvider.cs" />
	  <Compile Remove="UOW\IRawRepository.cs" />
	  <Compile Remove="UOW\UnregisteredRepositoryException.cs" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.1" />
	</ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="..\KUtiitiesCore.Encryption\KUtilitiesCore.Encryption.csproj" />
	  <ProjectReference Include="..\KUtilities.Logger\KUtilitiesCore.Logger.csproj" />
	  <ProjectReference Include="..\KUtilitiesCore.DataAccess\KUtilitiesCore.DataAccess.csproj" />
	  <ProjectReference Include="..\KUtilitiesCore\KUtilitiesCore.csproj" />
	</ItemGroup>
</Project>
